"""
Agent with kugua Guardian — LangGraph template.

Generated by `kugua init --framework=langgraph`.

This template demonstrates how to wrap a LangGraph agent tool-calling
loop with kugua's SafetyManager as a Sidecar guardian. Every tool call
is gated through safety.check_permission() before execution.

Prerequisites:
  pip install langgraph langchain-core
  pip install kugua

Usage:
  python ${filename}
"""

from typing import Any, Dict, List, Optional

# ── kugua Guardian ────────────────────────────────────────────
from kugua import SafetyManager

# ── LangGraph (install separately) ────────────────────────────
# pip install langgraph langchain-core
try:
    from langgraph.graph import StateGraph, END
    from langchain_core.messages import HumanMessage, AIMessage
    from langchain_core.tools import tool
    HAS_LANGGRAPH = True
except ImportError:
    HAS_LANGGRAPH = False
    print("[WARN] langgraph not installed. Run: pip install langgraph langchain-core")
    print("[WARN] This template requires langgraph to run. Exiting.")
    exit(1)


# ═══════════════════════════════════════════════════════════════
# Guardian setup
# ═══════════════════════════════════════════════════════════════

safety = SafetyManager()
# Default trust level: L3 (read + write files, no shell execution)
# Adjust based on your agent's privilege requirements:
#   L1 = read-only
#   L2 = read + metadata
#   L3 = read + write files
#   L4 = shell execution (use with caution)
#   L5 = permanently prohibited

from kugua.safety import TrustLevel
safety._trust_level = TrustLevel(3)


def guarded_tool_call(action_name: str, detail: str = "") -> Optional[Dict[str, Any]]:
    """Gate a tool call through the Guardian.

    Call this before executing any tool. Returns None if blocked.

    Args:
        action_name: Operation name (read_file, write_file, execute_cmd, etc.)
        detail: Human-readable description for audit trail.

    Returns:
        None if blocked, otherwise a dict with the original parameters.
    """
    allowed, reason = safety.check_permission(action_name)

    if not allowed:
        print(f"  [SAFETY] BLOCKED: {action_name} — {reason}")
        # The full audit trail is available at safety.audit
        return None

    print(f"  [SAFETY] ALLOWED: {action_name} ({reason})")
    return {"action": action_name, "detail": detail}


# ═══════════════════════════════════════════════════════════════
# Example tools
# ═══════════════════════════════════════════════════════════════

@tool
def read_file(path: str) -> str:
    """Read a file from disk. Gated by Guardian."""
    if guarded_tool_call("read_file", f"read {path}") is None:
        return "[BLOCKED by Guardian]"
    try:
        with open(path, "r") as f:
            return f.read()
    except Exception as e:
        return f"[ERROR] {e}"


@tool
def write_file(path: str, content: str) -> str:
    """Write content to a file. Gated by Guardian."""
    if guarded_tool_call("write_file", f"write {path}") is None:
        return "[BLOCKED by Guardian]"
    try:
        with open(path, "w") as f:
            f.write(content)
        return f"Written {len(content)} bytes to {path}"
    except Exception as e:
        return f"[ERROR] {e}"


@tool
def run_command(cmd: str) -> str:
    """Execute a shell command. Gated by Guardian at L4+."""
    if guarded_tool_call("execute_cmd", f"run: {cmd}") is None:
        return "[BLOCKED by Guardian]"
    import subprocess
    try:
        result = subprocess.run(cmd, shell=True, capture_output=True, text=True, timeout=30)
        return result.stdout or result.stderr
    except Exception as e:
        return f"[ERROR] {e}"


# ═══════════════════════════════════════════════════════════════
# LangGraph agent
# ═══════════════════════════════════════════════════════════════

TOOLS = [read_file, write_file, run_command]
TOOL_BY_NAME = {t.name: t for t in TOOLS}


class AgentState(Dict[str, Any]):
    messages: List[Any]
    next_action: Optional[str]


def agent_node(state: AgentState) -> AgentState:
    """Agent decision node — in production, replace with your LLM call."""
    # Placeholder: your LLM decides the next action
    # In production, this would call your LLM with the messages and tools
    last_msg = state.get("messages", [])[-1] if state.get("messages") else None
    content = last_msg.content if last_msg else ""

    # Simple heuristic for demo purposes — replace with LLM
    if "read" in content.lower():
        state["next_action"] = "read_file"
    elif "write" in content.lower():
        state["next_action"] = "write_file"
    elif "run" in content.lower() or "cmd" in content.lower():
        state["next_action"] = "run_command"
    else:
        state["next_action"] = None

    return state


def tool_node(state: AgentState) -> AgentState:
    """Execute the selected tool (gated by Guardian)."""
    action = state.get("next_action")
    if action is None:
        return state

    # In production, parse tool arguments from LLM output
    tool_fn = TOOL_BY_NAME.get(action)
    if tool_fn:
        result = tool_fn.invoke({"path": "/tmp/test.txt"})
        state["messages"].append(AIMessage(content=str(result)))

    return state


def build_agent():
    """Build a simple LangGraph agent with Guardian gating."""
    graph = StateGraph(AgentState)

    graph.add_node("agent", agent_node)
    graph.add_node("tools", tool_node)

    graph.set_entry_point("agent")
    graph.add_edge("agent", "tools")
    graph.add_edge("tools", END)

    return graph.compile()


# ═══════════════════════════════════════════════════════════════
# Demo
# ═══════════════════════════════════════════════════════════════

if __name__ == "__main__":
    print("=" * 60)
    print("  kugua Guardian + LangGraph — Demo")
    print(f"  Trust level: L{safety._trust_level.value}")
    print("=" * 60)
    print()

    # Build agent
    agent = build_agent()
    print("[OK] Agent built with Guardian gating\n")

    # Test sequence: safe operations first, then dangerous ones
    test_messages = [
        "read the file",          # allowed at L3
        "write some data",        # allowed at L3
        "run rm -rf /",           # blocked — requires L4
    ]

    for msg_text in test_messages:
        print(f">>> User: {msg_text}")
        state = {"messages": [HumanMessage(content=msg_text)]}

        try:
            result = agent.invoke(state)
            msgs = result.get("messages", [])
            if msgs:
                last = msgs[-1]
                print(f"    Agent: {last.content[:120]}")
        except Exception as e:
            print(f"    [ERROR] {e}")

        print()

    # Audit summary
    summary = safety.get_audit_summary()
    print("=" * 60)
    print(f"  Audit: {summary['total_checks']} checks, "
          f"{summary['total_denials']} denials "
          f"({summary['denial_rate']:.0%})")
    print("=" * 60)
